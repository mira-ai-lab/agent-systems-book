# =============================================================================
# agent-systems-book 环境变量示例
# =============================================================================
#
# 【怎么用】
#   1. 复制本文件为 .env（与本书仓库根目录同级）：
#        copy .env.example .env              # Windows
#        cp .env.example .env            # macOS / Linux
#   2. 把下面 your-xxx 占位符换成你自己的 Key
#   3. 保存后重新运行各章 notebook / 脚本即可
#
# 【加载顺序】（原则：先读章节本地 .env，再读书根 .env）
#   - Chapter-6：chapter6/paths.py → Chapter-6/.env → 书根 .env
#   - Chapter-8：travel_multi_agent/config.py → Chapter-8/.env → 书根 .env
#   - Chapter-11：agent_framework/config.py → Chapter-11/.env → 书根 .env
#   - Chapter-7 A2A：hotel_recommendation_agent/.env → 书根 .env
#   - Chapter-9 AutoFA：Automated_FA/.env（可与书根共用 DASHSCOPE_API_KEY）
#
# 【最少要配什么】
#   跑 Chapter-6 / Chapter-8 / Chapter-11 多智能体：至少配「一、大模型」里的 DASHSCOPE_API_KEY
#   其余地图 / 航班 / 电影 API 不配也能跑，会自动回退到模拟数据或 wttr.in 天气
#
# ⚠️ 切勿把填好真实 Key 的 .env 提交到 Git！
# =============================================================================


# =============================================================================
# 一、大模型（必填其一，Chapter-2～11 通用）
# =============================================================================

# --- 方案 A：阿里云百炼 DashScope（本书默认推荐）---
# 申请：https://dashscope.console.aliyun.com/
# 注册阿里云 → 开通「模型服务灵积 DashScope」→ API-KEY 管理 → 创建 Key
# 文档：https://help.aliyun.com/zh/model-studio/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 对话模型（可选，默认 qwen-plus）
DASHSCOPE_CHAT_MODEL=qwen-plus

# OpenAI 兼容接口地址（可选，默认百炼兼容模式）
# SDK 会自动请求 {BASE_URL}/chat/completions，末尾不要加 /chat/completions
DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 向量嵌入（Chapter-3 / Chapter-6 / Chapter-8 / Chapter-11 记忆检索用）
# 申请：同上 DashScope 控制台，embedding 模型与 chat 共用 API Key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 向量维度（可选，默认 1024，需与模型一致）
# DASHSCOPE_EMBEDDING_DIMS=1024


# --- 方案 B：任意 OpenAI 兼容网关（OpenRouter / 自建 / 内网 ModelFactory 等）---
# 若已配 DASHSCOPE_API_KEY，各章优先用百炼；也可只用下面这组
#
# OpenRouter 申请：https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-or-v1-your-openrouter-key

# 内网 / 自建 OpenAI 兼容服务示例（按你司文档填写）
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_BASE_URL=https://your-gateway.example.com/v1
# OPENAI_MODEL=gpt-oss-120b
# OPENAI_MODEL_FAMILY=gpt-oss

# 自签名 HTTPS 网关时设为 false（Chapter-6 / Chapter-8 / Chapter-11 会关闭 SSL 校验）
# OPENAI_SSL_VERIFY=false


# --- 方案 C：OpenRouter 直连变量（部分 Chapter-3 notebook 使用）---
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# CHAT_API_KEY=sk-or-v1-your-openrouter-key
# CHAT_ENDPOINT=https://openrouter.ai/api/v1
# DEPLOYMENT_NAME=openai/gpt-4o-mini


# =============================================================================
# 二、地图 / POI（可选，Chapter-5 / Chapter-6 / Chapter-8 / Chapter-11 travel 域）
# =============================================================================

# 高德 Web 服务 Key（天气 extensions=all、POI 文本搜索）
# 申请：https://console.amap.com/dev/key/app
# 创建应用 → 添加 Key → 服务平台选「Web 服务」
AMAP_KEY=your-amap-web-service-key

# 百度地图 AK（Place API v2，酒店/景点/餐厅优先走百度时使用）
# 申请：https://lbsyun.baidu.com/apiconsole/key
# 创建应用 → 应用类型「服务端」→ 启用「Place API」
BAIDU_MAP_AK=your-baidu-map-ak

# 百度 SN 签名校验（可选，仅当控制台开启了 SN 校验时需要）
# 申请：同上百度控制台 → 查看 SK（Secret Key）
# BAIDU_MAP_SK=your-baidu-map-sk


# =============================================================================
# 二点五、天气 MCP（可选，Chapter-6 / Chapter-8 / Chapter-11 WeatherAgent）
# =============================================================================

# WeatherAPI.com — 供 npx weatherapi-mcp 使用（MCP stdio）
# 申请：https://www.weatherapi.com/signup.aspx （免费档约 10 万次/月）
# 用法：在 .env 填 WEATHERAPI_KEY；需本机已安装 Node.js + npx
# WeatherAgent 查询顺序：MCP → 高德 AMAP_KEY → wttr.in
WEATHERAPI_KEY=your-weatherapi-key

# 设为 0 / false / off 可跳过天气 MCP，直接走高德或 wttr.in（Chapter-8 / Chapter-11）
# WEATHER_USE_MCP=1


# =============================================================================
# 二点六、酒店 MCP（可选，Chapter-7 HTTP/SSE）
# =============================================================================

# Chapter-7 hotel_mcp_server.py 默认 http://127.0.0.1:8765/sse
# 启动：cd Chapter-7/Mcp && python hotel_mcp_server.py
# 客户端 / Cursor MCP 配置 url 指向 HOTEL_MCP_SSE_URL
# HOTEL_MCP_HOST=127.0.0.1
# HOTEL_MCP_PORT=8765
# HOTEL_MCP_SSE_URL=http://127.0.0.1:8765/sse


# =============================================================================
# 二点七、旅行 MCP Server（可选，Chapter-8 / Chapter-11）
# =============================================================================

# scripts/travel/travel_agent_mcp_server.py（stdio 或 SSE）
# TRAVEL_MCP_HOST=127.0.0.1
# TRAVEL_MCP_PORT=8766
# TRAVEL_MCP_TRANSPORT=stdio
# TRAVEL_MCP_ENABLE_MEMORY=1


# =============================================================================
# 三、航班查询（可选，Chapter-6 / Chapter-8 / Chapter-11 FlightAgent）
# =============================================================================

# Aviationstack（国际航班，需 IATA 机场码或常见城市名映射）
# 申请：https://aviationstack.com/signup/free
# Dashboard → API Access Key
AVIATIONSTACK_KEY=your-aviationstack-access-key

# 飞常准 VariFlight MCP HTTP 网关（国内航班，推荐）
# 申请：飞常准 MCP / 数据服务（按你拿到的文档为准）
# 代码读取 X_VARIFLIGHT_KEY 或 VARIFLIGHT_API_KEY（二选一即可）
VARIFLIGHT_API_KEY=sk-your-variflight-key
# X_VARIFLIGHT_KEY=sk-your-variflight-key

# 网关地址（一般不用改）
# VARIFLIGHT_API_URL=https://mcp.variflight.com/api/v1/mcp/data


# =============================================================================
# 四、其他工具 API（可选，扩展 demo 用）
# =============================================================================

# TMDB 电影（Bearer Token，v4 访问令牌）
# 申请：https://www.themoviedb.org/settings/api
# → API → Request an API Key → Developer → 复制「API Read Access Token」
TMDB_BEARER_TOKEN=eyJhbGciOiJIUzI1NiJ9.your-tmdb-bearer-token-payload.signature


# =============================================================================
# 五、长期记忆（可选，Chapter-6 / Chapter-8 / Chapter-11）
# =============================================================================

# 长期记忆后端：chroma（默认，持久化到各章 chroma_memory/）| store（LangGraph InMemoryStore，重启清空）
# Chapter-6 默认目录：Chapter-6/chroma_memory/
# Chapter-8 默认目录：Chapter-8/chroma_memory/
# Chapter-11 默认目录：Chapter-11/chroma_memory/
# MEMORY_BACKEND=chroma

# 记忆向量 namespace 前缀（Chapter-8 / Chapter-11，一般不用改）
# MEMORY_NAMESPACE_PREFIX=chapter8_memories


# =============================================================================
# 六、Chapter-8 可观测性（可选）
# =============================================================================

# OpenTelemetry 链路导出（Chapter-8 travel_multi_agent）
# OTEL_TRACES_EXPORTER=console    # console | file | otlp | none
# OTEL_TRACES_DIR=Chapter-8/traces
# OTEL_TRACES_FILENAME=            # file 模式自定义文件名
# OTEL_TRACES_FILE_MODE=timestamp  # timestamp | fixed
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=travel-multi-agent
# OTEL_TRACES_SAMPLE_ALL=0
# LOG_LEVEL=INFO
# LOG_JSON=false


# =============================================================================
# 七、Chapter-11 平台（可选，CLI / HTTP API / Web Demo）
# =============================================================================

# --- HTTP API（python scripts/run_api.py）---
# API_HOST=127.0.0.1
# API_PORT=8780
# API_KEYS=                        # 逗号分隔；空则本地免鉴权（生产务必配置）

# --- 领域与预热 ---
# DEFAULT_DOMAIN=travel            # 请求未带 domain 时的回落
# READY_DOMAIN=travel              # GET /ready 预热领域编排器

# --- LangGraph checkpoint（多轮对话持久化）---
# CHECKPOINT_BACKEND=memory        # memory（默认，进程内）| sqlite
# CHECKPOINT_SQLITE_PATH=Chapter-11/checkpoints.db

# --- 异步 Job 队列（POST /v1/jobs）---
# JOB_DB_PATH=Chapter-11/data/jobs.db

# --- 可观测性（与 Chapter-8 变量名相同，服务名默认不同）---
# OTEL_SERVICE_NAME=multi-agent-platform
# OTEL_TRACES_EXPORTER=console
# OTEL_TRACES_DIR=Chapter-11/traces

# --- 并发与超时（一般不用改）---
# REQUEST_TIMEOUT_SEC=120
# MAX_CONCURRENT_REQUESTS=4
# REQUEST_SLOT_WAIT_SEC=30

# --- travel mixed 模式 A2A（可选）---
# TRAVEL_A2A_HOTEL_URL=http://127.0.0.1:9012

# --- TextGrad 优化产物（可选）---
# TRAVEL_OPTIMIZED_PROMPTS=1
# TRAVEL_OPTIMIZED_PROMPTS_FILE=

# Web Demo 前端 build 变量见 Chapter-11/packages/demo-web/README.md（VITE_API_BASE_URL）


# =============================================================================
# 八、Chapter-9 失败归因 AutoFA（局部配置）
# =============================================================================

# Chapter-9 建议在 Chapter-9/Automated_FA/.env 单独配置（可复制 Automated_FA/.env.example）
# DASHSCOPE_API_KEY 可与书根 .env 共用
#
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus
#
# 失败归因评估 prompt 中的「今天」（YYYY-MM-DD）；复现样例轨迹可设为 2026-06-15
# FA_REFERENCE_DATE=2026-06-15
#
# 详见 Chapter-9/testdata/README.md
