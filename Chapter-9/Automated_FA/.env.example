# ============================================================
# 通义千问（DashScope）OpenAI 兼容模式 —— 推荐
# 获取 Key：https://dashscope.console.aliyun.com/
# ============================================================
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 可选：失败归因评估时注入 prompt 的「今天」（YYYY-MM-DD）
# 样例轨迹录制于 2026-06-15，复现实验时可设为：FA_REFERENCE_DATE=2026-06-15
# FA_REFERENCE_DATE=2026-06-15

# ============================================================
# Azure OpenAI（仅在使用 gpt-4o / gpt4 时需要，可留空）
# ============================================================
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
